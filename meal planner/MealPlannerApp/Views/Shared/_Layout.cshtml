@{
    var useWideLayout = ViewData["UseWideLayout"] as bool? == true;
    var bodyClass = ViewData["BodyClass"] as string;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MealPlannerApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="@bodyClass">
<header>
    <nav class="navbar navbar-expand bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold text-white" asp-controller="Home" asp-action="Index">MealPlannerApp</a>
            <div class="ms-auto d-flex flex-wrap align-items-center gap-2">
                <a class="btn btn-outline-light btn-sm" asp-controller="Home" asp-action="Index">Home</a>
                <a class="btn btn-outline-light btn-sm" asp-controller="Recipes" asp-action="Index">Recipes</a>
                <a class="btn btn-outline-light btn-sm" asp-controller="Ingredients" asp-action="Index">Ingredients</a>
                <a class="btn btn-outline-light btn-sm" asp-controller="MealPlanTemplates" asp-action="Index">Shared Plans</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="btn btn-outline-light btn-sm" asp-controller="MealPlans" asp-action="Index">Meal Plans</a>
                    <a class="btn btn-outline-light btn-sm" asp-controller="MealPlans" asp-action="Weekly">Weekly Planner</a>
                    <a class="btn btn-outline-light btn-sm" asp-controller="MealPlans" asp-action="History">Progress</a>
                    @if (User.IsInRole(ApplicationRoles.Admin))
                    {
                        <a class="btn btn-warning btn-sm" asp-controller="Recipes" asp-action="Moderation">Recipe Review</a>
                        <a class="btn btn-warning btn-sm" asp-controller="MealPlanTemplates" asp-action="Moderation">Plan Review</a>
                    }
                    <span class="text-white-50 small px-2">Signed in as <span class="text-white">@User.Identity.Name</span></span>
                    @if (User.IsInRole(ApplicationRoles.Admin))
                    {
                        <span class="badge text-bg-warning">Admin</span>
                    }
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="btn btn-light btn-sm">Log Out</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Login">Log In</a>
                    <a class="btn btn-light btn-sm" asp-controller="Account" asp-action="Register">Register</a>
                }
            </div>
        </div>
    </nav>
</header>

<div class="@(useWideLayout ? "app-wide-layout" : "container mt-4")">
    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success @(useWideLayout ? "app-wide-layout__alert" : string.Empty)" role="alert">@successMessage</div>
    }
    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger @(useWideLayout ? "app-wide-layout__alert" : string.Empty)" role="alert">@errorMessage</div>
    }
    <main role="main">
        @RenderBody()
    </main>
</div>

<footer class="bg-light text-center text-muted mt-5 p-3 border-top">
    <div class="container">
        &copy; 2026 - MealPlannerApp
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
