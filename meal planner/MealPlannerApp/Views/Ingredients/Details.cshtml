@model MealPlannerApp.Dtos.Ingredients.IngredientDto
@{
    ViewData["Title"] = "Ingredient Details";
}

<div class="card">
    <div class="card-header">
        <h1 class="h5 mb-0">@Model.Name</h1>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Calories / 100g</dt>
            <dd class="col-sm-8">@Model.CaloriesPer100g</dd>
            <dt class="col-sm-4">Protein / 100g</dt>
            <dd class="col-sm-8">@Model.ProteinPer100g.ToString("0.#") g</dd>
            <dt class="col-sm-4">Carbs / 100g</dt>
            <dd class="col-sm-8">@Model.CarbsPer100g.ToString("0.#") g</dd>
            <dt class="col-sm-4">Fat / 100g</dt>
            <dd class="col-sm-8">@Model.FatPer100g.ToString("0.#") g</dd>
        </dl>
    </div>
</div>

<div class="mt-3 d-flex gap-2">
    @if (User.IsInRole(ApplicationRoles.Admin))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete</a>
    }
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</div>
