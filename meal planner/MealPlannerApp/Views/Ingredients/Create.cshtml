@model MealPlannerApp.Dtos.Ingredients.IngredientDto
@{
    ViewData["Title"] = "Create Ingredient";
}

<h1 class="h3 mb-3">Create Ingredient</h1>

<form asp-action="Create" method="post" class="card card-body">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CaloriesPer100g" class="form-label"></label>
        <input asp-for="CaloriesPer100g" class="form-control" />
        <span asp-validation-for="CaloriesPer100g" class="text-danger"></span>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <label asp-for="ProteinPer100g" class="form-label"></label>
            <input asp-for="ProteinPer100g" class="form-control" min="0" max="100" step="0.1" />
            <span asp-validation-for="ProteinPer100g" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="CarbsPer100g" class="form-label"></label>
            <input asp-for="CarbsPer100g" class="form-control" min="0" max="100" step="0.1" />
            <span asp-validation-for="CarbsPer100g" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="FatPer100g" class="form-label"></label>
            <input asp-for="FatPer100g" class="form-control" min="0" max="100" step="0.1" />
            <span asp-validation-for="FatPer100g" class="text-danger"></span>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
