@model MealPlannerApp.Dtos.MealPlanTemplates.MealPlanTemplateDto
@{
    ViewData["Title"] = "Plan Template Details";
    var isOwner = User.Identity?.IsAuthenticated == true && Model.OwnerId == User.GetRequiredUserId();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">@Model.Name</h1>
        <p class="text-muted mb-0">By @Model.OwnerUserName</p>
    </div>
    <span class="badge @GetBadgeClass(Model.ApprovalStatus)">@Model.ApprovalStatus</span>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Description))
{
    <div class="card mb-3">
        <div class="card-body">
            @Model.Description
        </div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.ReviewNotes))
{
    <div class="alert alert-warning">
        <strong>Admin feedback:</strong> @Model.ReviewNotes
    </div>
}

<div class="d-flex flex-wrap gap-2 mb-4">
    @if (User.Identity?.IsAuthenticated == true && (Model.ApprovalStatus == ApprovalStatus.Approved || isOwner || User.IsInRole(ApplicationRoles.Admin)))
    {
        <form asp-action="Apply" method="post" class="d-flex gap-2">
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="date" name="weekStart" value="@WeekDateHelper.GetCurrentWeekStart().ToString("yyyy-MM-dd")" class="form-control" />
            <button type="submit" class="btn btn-primary">Apply To My Week</button>
        </form>
    }
    @if (isOwner && Model.ApprovalStatus != ApprovalStatus.PendingReview && Model.ApprovalStatus != ApprovalStatus.Approved)
    {
        <form asp-action="SubmitForReview" method="post" class="d-inline">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-success">Submit For Review</button>
        </form>
    }
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h2 class="h6 text-muted">Week Template Calories</h2>
                <div class="display-6">@Model.WeeklyTotalCalories</div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h2 class="h6 text-muted">Created</h2>
                <div class="fs-5">@Model.CreatedAt.ToString("dd MMM yyyy")</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    @foreach (var day in Model.Days)
    {
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between">
                    <span>@day.Date:dddd, dd MMM</span>
                    <span class="fw-semibold">@day.TotalCalories kcal</span>
                </div>
                <div class="card-body">
                    @if (day.Meals.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var meal in day.Meals)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-start px-0">
                                    <div>
                                        <div>
                                            <strong>@meal.MealType</strong>:
                                            <a asp-controller="Recipes" asp-action="Details" asp-route-id="@meal.RecipeId">@meal.RecipeName</a>
                                        </div>
                                        <div class="small text-muted">Portion x @meal.PortionMultiplier.ToString("0.#")</div>
                                    </div>
                                    <span>@meal.Calories kcal</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No meals added.</p>
                    }
                </div>
            </div>
        </div>
    }
</div>

@functions {
    private static string GetBadgeClass(ApprovalStatus status)
    {
        return status switch
        {
            ApprovalStatus.Approved => "text-bg-success",
            ApprovalStatus.PendingReview => "text-bg-warning",
            ApprovalStatus.Rejected => "text-bg-danger",
            _ => "text-bg-secondary"
        };
    }
}
